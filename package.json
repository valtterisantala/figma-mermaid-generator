{
  "name": "figma-mermaid-generator",
  "version": "0.1.0",
  "private": true,
  "description": "A Figma plugin foundation for rendering Mermaid flowcharts as editable native Figma objects.",
  "type": "module",
  "scripts": {
    "build": "npm run clean && npm run build:main && npm run build:ui",
    "build:main": "esbuild src/main/index.ts --bundle --outfile=dist/main.js --format=iife --target=es2019",
    "build:ui": "node scripts/build-ui.mjs",
    "clean": "rimraf dist",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "figma",
    "figma-plugin",
    "mermaid"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@figma/plugin-typings": "^1.124.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0"
  }
}
